# Supabase - server runtime
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Server only. Never expose this through a VITE_* variable.
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Express
PORT=3001
WEB_ORIGIN=http://localhost:5173,http://192.168.0.234,http://192.168.0.234:5173
TRUST_PROXY=false

# Browser values belong in apps/web/.env.local.
# Copy apps/web/.env.example and use the same URL and publishable key.
